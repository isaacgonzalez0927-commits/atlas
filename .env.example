# One code for your whole team (Isaac + Sebastien). Unlocks full Atlas OS.
ATLAS_CODE=your-team-code-here

# Optional — logged on lead outcomes
# CALLER_NAME=sebastien

# Lead generation (required for Leads page)
GOOGLE_MAPS_API_KEY=

# Learning / AI lead scoring (optional)
OPENAI_API_KEY=

# Local dev only
# ATLAS_DB_PATH=data/atlas.db
# ATLAS_DATA_DIR=data

# Recommended on Render — auto-backup so deploys never wipe data
# ATLAS_GITHUB_TOKEN=ghp_...
# ATLAS_GITHUB_REPO=isaacgonzalez0927-commits/atlas
# ATLAS_GITHUB_PATH=atlas-snapshot.json
